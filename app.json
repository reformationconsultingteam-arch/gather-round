{
  "expo": {
    "name": "Gather Round",
    "slug": "gather-round",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gatherround",
    "platforms": ["web"],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "single",
      "name": "Gather Round",
      "shortName": "Gather Round",
      "themeColor": "#1a1a2e",
      "backgroundColor": "#1a1a2e",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "en"
    },
    "experiments": {
      "baseUrl": "/gather-round"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
