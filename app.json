{
  "expo": {
    "name": "Gather Round",
    "slug": "gather-round",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gatherround",
    "platforms": ["ios"],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "bundleIdentifier": "com.gatherround.app",
      "supportsTablet": false,
      "buildNumber": "1"
    },
    "plugins": [
      "expo-router",
      "react-native-reanimated"
    ]
  }
}
